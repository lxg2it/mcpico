{
  "name": "mcpico",
  "version": "0.3.0",
  "description": "MCPico — MCP proxy that bundles flat tool lists into hierarchical subcommand groups. Pico footprint, maximum discovery.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcpico": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "proxy",
    "tools",
    "context",
    "hierarchical",
    "subcommand"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lxg2it/mcpico"
  },
  "homepage": "https://github.com/lxg2it/mcpico#readme",
  "bugs": {
    "url": "https://github.com/lxg2it/mcpico/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
